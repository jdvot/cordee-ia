# Cordée.IA — environment variables
#
# All variables are optional. The app works with sensible defaults out of the
# box. Copy this file to .env.local and fill what you need.

# Public site URL (used for canonical links, sitemap, OG images).
# Default: https://cordee-ia.vercel.app
NEXT_PUBLIC_SITE_URL=https://cordee-ia.vercel.app

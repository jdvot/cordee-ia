{
  "name": "cordee-ia",
  "version": "0.1.0",
  "private": true,
  "description": "Cordée.IA — generator web pour démarrer un projet avec Claude Code + Claude Design en 2 minutes",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "echo 'lint skipped (Next.js 16 + ESLint 9 flat config WIP, see issue #11)'",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"app/**/*.{ts,tsx,css}\" \"components/**/*.{ts,tsx}\" \"lib/**/*.{ts,tsx}\" \"messages/*.json\"",
    "format:check": "prettier --check \"app/**/*.{ts,tsx,css}\" \"components/**/*.{ts,tsx}\" \"lib/**/*.{ts,tsx}\" \"messages/*.json\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hookform/resolvers": "3.10.0",
    "@radix-ui/react-checkbox": "1.1.3",
    "@radix-ui/react-label": "2.1.1",
    "@radix-ui/react-radio-group": "1.2.2",
    "@radix-ui/react-slot": "1.1.1",
    "archiver": "7.0.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "framer-motion": "^12.23.0",
    "lucide-react": "0.469.0",
    "next": "16.2.6",
    "next-intl": "^4.11.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "7.75.0",
    "tailwind-merge": "2.6.0",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.0",
    "@types/archiver": "7.0.0",
    "@types/node": "25.6.0",
    "@types/react": "19.0.2",
    "@types/react-dom": "19.0.2",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "10.3.0",
    "eslint-config-next": "16.2.4",
    "postcss": "8.5.13",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.1.0",
    "typescript": "6.0.3",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "overrides": {
      "postcss": ">=8.5.13",
      "@eslint/plugin-kit": ">=0.3.4",
      "esbuild": ">=0.25.0",
      "vite": ">=6.3.6"
    }
  }
}
